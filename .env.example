# ─────────────────────────────────────────────────────────────────────────────
# Transcript Management System — Environment Variables
# Copy to .env.local for local development.
# In production, set these in your platform's secrets manager.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Authentication (REQUIRED) ────────────────────────────────────────────────

# JWT signing secret — at least 32 characters.
# Generate with:  openssl rand -base64 64
JWT_SECRET=replace_with_at_least_32_random_characters_change_before_deploying


# ─── Database (REQUIRED) ──────────────────────────────────────────────────────

# PostgreSQL connection string.
# Local dev:  postgresql://postgres:password@localhost:5432/tms_dev
# Neon:       postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/tms?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/tms_dev


# ─── PDF Generation ───────────────────────────────────────────────────────────

# Path to Chromium in Docker/Lambda/custom environments.
# Leave unset in local dev — Puppeteer downloads its own Chromium.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Vercel: use @sparticuz/chromium (see README for swap instructions)
# CHROMIUM_PATH=/tmp/chromium


# ─── File Storage — choose one provider ──────────────────────────────────────
# Leave all storage vars unset in local dev — files go to .transcripts/

# AWS S3
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_REGION=us-east-1
# S3_BUCKET=tms-transcripts-prod

# Cloudflare R2 (recommended — no egress fees)
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET=tms-transcripts

# MinIO (self-hosted)
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=tms-transcripts


# ─── Application ──────────────────────────────────────────────────────────────

# Public base URL — required for absolute links in any future email notifications.
# NEXT_PUBLIC_APP_URL=https://tms.yourinstitution.edu

# Node environment (set automatically by most platforms)
# NODE_ENV=production
